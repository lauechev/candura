---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="Candura — design and technology, thoughtfully made.">
  <section class="hero">
    <canvas id="node-canvas"></canvas>
    <div class="hero-content">
      <h1>Candura</h1>
      <h2 class="tagline">Design and technology, thoughtfully made.<h2></h2></h2>
    </div>

    <script>
      import { NodeNetwork } from '@/scripts/NodeNetwork';

      const canvas = document.getElementById('node-canvas') as HTMLCanvasElement;
      const network = new NodeNetwork(canvas);
      network.start();

      window.addEventListener('pagehide', () => network.destroy());
    </script>

    <style lang="scss">
      .hero {
        position: relative;
        width: 100%;
        height: 100vh;
        overflow: hidden;
      }

      canvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        display: block;
      }

      .hero-content {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        pointer-events: none;
      }

      h1 {
        font-family: var(--font-display);
        font-size: clamp(3rem, 10vw, 8rem);
        font-weight: 700;
        color: var(--black);
        margin: 0;
        line-height: 1;
        letter-spacing: -0.02em;
      }

      .tagline {
        font-family: var(--font-body);
        font-size: clamp(1rem, 2.5vw, 1.5rem);
        color: var(--black);
        margin: 1.25rem 0 0;
        opacity: 0.6;
      }
    </style>
  </section></BaseLayout
>
