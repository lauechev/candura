---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout pageHeading="Contact" title="Contact" description="Get in touch with Candura.">
  <main>
    <div class="contact-card">
      <div class="card-left">
        <h1>Let's talk</h1>
      </div>
      <div class="card-right">
        <p class="intro">Have a project in mind? We'd love to hear about it. Email us at:</p>
        <a href="mailto:candura.studio@gmail.com" class="email">💌 candura.studio@gmail.com</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style lang="scss">
  main {
    display: flex;
    justify-content: center;
    padding: 4.5rem 3rem 11.5rem;
  }

  .contact-card {
    display: grid;
    grid-template-columns: 38% 1fr;
    border: 2px solid var(--black);
    border-radius: 15px;
    overflow: hidden;
    width: 88vw;
    min-height: 28vh;
  }

  .card-left {
    background: var(--purple);
    display: flex;
    align-items: flex-end;
    padding: 2rem 3rem;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 7vw, 5.5rem);
    font-weight: 600;
    color: var(--white);
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .intro {
    font-family: var(--font-body);
    font-size: clamp(3.5rem, 8vw, 0.1rem);
    font-weight: 400;
    color: var(--white);
    letter-spacing: -0.02em;
  }

  .card-right {
    background: var(--white);
    border-left: 2px solid var(--black);
    padding: 2.5rem 3.5rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 1.5rem;
  }

  .intro {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--black);
    opacity: 0.65;
    margin: 0;
    max-width: 42ch;
  }

  .email {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    font-weight: 500;
    color: var(--black);
    text-decoration: none;
    letter-spacing: -0.01em;
    line-height: 1;

    &:hover {
      opacity: 0.6;
    }
  }

  @media (max-width: 768px) {
    .contact-card {
      grid-template-columns: 1fr;
      min-height: unset;
    }

    .card-left {
      min-height: 35vw;
      align-items: flex-end;
      border-bottom: 2px solid var(--black);
    }

    .card-right {
      border-left: none;
      padding: 3rem 2rem;
    }
  }
</style>
