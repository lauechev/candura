---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ImageText from '@/components/ImageText.astro';
---

<BaseLayout pageHeading="Contact" title="Contact" description="Get in touch with Candura.">
  <main>
    <div class="contact-wrapper">
      <ImageText
        color="transparent"
        title="Let's talk"
        description="Have a project in mind? We'd love to hear about it. Email us at:"
        image="/envelope.svg"
        imageSize="100%"
      >
        <a href="mailto:candura.studio@gmail.com" class="email">candura.studio@gmail.com</a>

        <div class="social-links">
          <p class="follow">Follow us on:</p>
          <div class="social-icons">
            <a href="https://www.instagram.com/candura.studio" target="_blank" rel="noopener noreferrer"
              ><img src="/ig.svg" alt="Instagram" /></a
            >
            <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer"
              ><img src="/linkedin.svg" alt="LinkedIn" /></a
            >
            <a href="https://substack.com" target="_blank" rel="noopener noreferrer"
              ><img src="/substack.svg" alt="Substack" /></a
            >
          </div>
        </div>
      </ImageText>
    </div>
  </main>
</BaseLayout>

<style lang="scss">
  main {
    display: flex;
    justify-content: center;
    padding: 4.5rem 3rem 11.5rem;
  }

  .contact-wrapper {
    width: 65vw;
    margin: 0 auto;

    :global(.about-split) {
      width: 100%;
    }

    :global(.split-text) {
      border-right: none;
      border-left: none;
    }

    :global(.split-image) {
      border-bottom: none;
    }
  }

  .email {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    font-weight: 500;
    color: var(--black);
    text-decoration: none;
    letter-spacing: -0.01em;
    line-height: 1;

    &:hover {
      opacity: 0.6;
    }
  }

  .social-links {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;

    .follow {
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 3.5vw, 2.5rem);
      font-weight: 500;
      color: var(--black);
      margin: 0;
      letter-spacing: -0.01em;
    }

    .social-icons {
      display: flex;
      flex-direction: row;
      gap: 1rem;
      align-items: center;
    }

    a {
      text-decoration: none;
      display: inline-block;

      &:hover {
        opacity: 0.6;
      }

      img {
        height: 1.5rem;
        width: auto;
      }
    }
  }

  @media (max-width: 1500px) {
    .contact-wrapper {
      width: 50vw;
    }
  }

  @media (max-width: 768px) {
    main {
      padding-top: 1.5rem;
    }

    .contact-wrapper {
      width: 100%;
    }
  }
</style>
