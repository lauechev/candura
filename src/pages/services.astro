---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Service from '@/components/Service.astro';

const pillars = [
  {
    title: 'Shopify Development',
    color: 'var(--red)',
    services: [
      {
        title: 'Complete Store',
        description:
          'You have a product and a vision. We build the storefront from the ground up: architecture, design, and development aligned from day one.',
      },
      {
        title: 'Store Expansion',
        description:
          "Your store exists. Now it needs to grow. We build on what's there and add new sections, new functionality, new pages without breaking what works.",
      },
      {
        title: 'Store Redesign',
        description:
          "Same store, entirely new direction. We audit what you have, define where you're going, and rebuild the experience around it.",
      },
    ],
  },
  {
    title: 'Web Development',
    color: 'var(--pink)',
    services: [
      {
        title: 'Website Development',
        description: 'Landing pages, full-on digital journeys, and everything in between, we build it.',
      },
      {
        title: 'Data Visualization Development',
        description:
          'More than just charts and graphs, we offer holistic interactive data experiences. Turn your databases into powerful stories with our bespoke data visualization development.',
      },
    ],
  },
  {
    title: 'Design',
    color: 'var(--green)',
    services: [
      {
        title: 'UX/UI & Interface Design',
        description:
          'Thoughtful interfaces, designed from the ground up. We think through every interaction so your users never have to.',
      },
      {
        title: 'Design Systems',
        description:
          'A coherent visual language expressed in components, tokens, and documentation. Design that scales without losing integrity.',
      },
      {
        title: 'Data Visualization',
        description:
          'How you present data is a design problem. We shape complex information into something legible, precise, and visually coherent.',
      },
      {
        title: 'Illustration',
        description: 'Illustrations made from scratch, built entirely around your brand.',
      },
      {
        title: 'Brand Universe',
        description:
          'We define the visual direction: color, typography, spatial language, tone — and shape a cohesive brand world.',
      },
    ],
  },
  {
    title: 'Consulting & Strategy',
    color: 'var(--orange)',
    services: [
      {
        title: 'UI/UX Audit',
        description:
          "A structured review of your interface: what's working, what's creating friction, and what to prioritize. Delivered as a clear, actionable report.",
      },
      {
        title: 'Shopify Audit',
        description:
          'We go through your store the way a first-time visitor would, then the way an analyst would. You get both perspectives in one document.',
      },
      {
        title: 'Creative Consulting',
        description:
          'For teams that have executional resources but need directional clarity. We help define or sharpen the visual language of your brand.',
      },
    ],
  },
];
---

<BaseLayout pageHeading="Services" title="Services" description="What Candura offers — from strategy to execution.">
  <main class="container">
    <div class="pillars">
      {pillars.map((pillar) => <Service title={pillar.title} color={pillar.color} services={pillar.services} />)}
    </div>
  </main>
</BaseLayout>

<style lang="scss">
  main {
    padding-top: 1rem;
    padding-bottom: 3rem;
  }

  .pillars {
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 768px) {
    main {
      padding-bottom: 8rem;
    }
  }
</style>
