---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PhotoAndDescription from '@/components/PhotoAndDescription.astro';

const bienvenides = '/bienvenides.png';
const sanarte = '/sanarte.png';
const type = '/type-checker.png';
const news = '/newsletter.png';
const ebook2 = '/ebook2.png';
const art = '/art.png';
const ux = '/ux.png';
---

<BaseLayout title="Work" pageHeading="Work" description="Selected projects by Candura.">
  <main class="container">
    <p class="intro">A selection of projects we've brought to life for brands we love working with.</p>
    <div class="grid">
      <PhotoAndDescription description="Shopify Store Development" image={sanarte} color="var(--blue)" />
      <PhotoAndDescription description="History of the Internet Website" image={ux} color="var(--pink)" />
      <PhotoAndDescription description="Typeface Checker Website" image={type} color="var(--purple)" />
      <PhotoAndDescription description="Digital Art Collection Website" image={art} color="var(--red)" />
      <PhotoAndDescription description="Newsletter Visual Universe" image={news} color="var(--green)" />
      <PhotoAndDescription description="Ebook Creative Direction & Design" image={ebook2} color="var(--orange)" />
    </div>
  </main>
</BaseLayout>

<style lang="scss">
  main {
    padding-top: 4rem;
    padding-bottom: 6rem;

    @media (max-width: 768px) {
      padding-top: 3rem;
    }
  }

  .intro {
    font-family: var(--font-body);
    font-size: 1.4rem;
    line-height: 1.6;
    color: var(--black);
    margin: 0 0 3rem;
    max-width: 50rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;

    @media (max-width: 760px) {
      grid-template-columns: 1fr;
    }
  }
</style>
