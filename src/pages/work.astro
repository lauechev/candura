---
import BaseLayout from '@/layouts/BaseLayout.astro';

const projects = [
  {
    title: 'Project Title',
    description: 'A short description of the project goes here. Replace with the real summary.',
    category: 'Brand Identity',
    color: 'var(--blue)',
  },
  {
    title: 'Project Title',
    description: 'A short description of the project goes here. Replace with the real summary.',
    category: 'Digital Design',
    color: 'var(--purple)',
  },
  {
    title: 'Project Title',
    description: 'A short description of the project goes here. Replace with the real summary.',
    category: 'Development',
    color: 'var(--yellow)',
  },
  {
    title: 'Project Title',
    description: 'A short description of the project goes here. Replace with the real summary.',
    category: 'Strategy',
    color: 'var(--orange)',
  },
  {
    title: 'Project Title',
    description: 'A short description of the project goes here. Replace with the real summary.',
    category: 'Motion',
    color: 'var(--pink)',
  },
  {
    title: 'Project Title',
    description: 'A short description of the project goes here. Replace with the real summary.',
    category: 'Content',
    color: 'var(--green)',
  },
];
---

<BaseLayout title="Work" description="Selected projects by Candura.">
  <main class="container">
    <header class="page-header">
      <div class="accent-rule"></div>
      <h1>Work</h1>
    </header>

    <div class="grid">
      {
        projects.map((project) => (
          <article class="card" style={`--accent: ${project.color}`}>
            <div class="card-image" />
            <div class="card-body">
              <span class="tag" style={`--accent: ${project.color}`}>
                {project.category}
              </span>
              <h2>{project.title}</h2>
              <p>{project.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </main>
</BaseLayout>

<style lang="scss">
  main {
    padding-top: 5rem;
    padding-bottom: 6rem;
  }

  .page-header {
    margin-bottom: 4rem;
  }

  .accent-rule {
    width: 3rem;
    height: 4px;
    background-color: var(--yellow);
    margin-bottom: 1.5rem;
    border-radius: 2px;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    color: var(--black);
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;

    @media (max-width: 900px) {
      grid-template-columns: repeat(2, 1fr);
    }

    @media (max-width: 560px) {
      grid-template-columns: 1fr;
    }
  }

  .card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 4px;
    overflow: hidden;
  }

  .card-image {
    aspect-ratio: 16 / 10;
    background-color: rgba(0, 0, 0, 0.04);
    border-bottom: 3px solid var(--accent);
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--accent);
    border-radius: 999px;
    width: fit-content;
  }

  h2 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--black);
    margin: 0;
  }

  p {
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--black);
    opacity: 0.6;
    margin: 0;
  }
</style>
