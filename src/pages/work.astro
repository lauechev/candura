---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PhotoAndDescription from '@/components/PhotoAndDescription.astro';

const floppy = '/floppy.svg';
---

<BaseLayout title="Work" pageHeading="Work" description="Selected projects by Candura.">
  <main class="container">
    <p class="intro">A selection of projects we've brought to life for brands we love working with.</p>
    <div class="grid">
      <PhotoAndDescription description="Shopify Store Development" image={floppy} color="var(--blue)" />
      <PhotoAndDescription description="Landing Page" image={floppy} color="var(--purple)" />
      <PhotoAndDescription description="Brand Visual Universe" image={floppy} color="var(--red)" />
      <PhotoAndDescription description="Ebook Creative Direction & Design" image={floppy} color="var(--orange)" />
      <PhotoAndDescription description="Podcast Cover Art" image={floppy} color="var(--pink)" />
      <PhotoAndDescription description="Typeface Checker Website" image={floppy} color="var(--green)" />
    </div>
  </main>
</BaseLayout>

<style lang="scss">
  main {
    padding-top: 5rem;
    padding-bottom: 6rem;
  }

  .intro {
    font-family: var(--font-body);
    font-size: 1.4rem;
    line-height: 1.6;
    color: var(--black);
    margin: 0 0 3rem;
    max-width: 50rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;

    @media (max-width: 900px) {
      grid-template-columns: repeat(2, 1fr);
    }

    @media (max-width: 560px) {
      grid-template-columns: 1fr;
    }
  }
</style>
