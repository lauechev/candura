---

<section class="intro">
  <div class="intro-left">
    <img src="/pixel-computer.svg" alt="Computer illustration" />
  </div>

  <div class="intro-right">
    <h2>We help brands get where they're going through boundless design and technology sharp enough to execute it.</h2>
  </div>
</section>

<style lang="scss">
  .intro {
    display: grid;
    grid-template-columns: 38% 1fr;
    border: 2px solid var(--black);
    border-radius: 15px;
    overflow: hidden;
    min-height: 40vh;
    width: calc(100vw - 2rem);
    margin: 0 auto 1rem;
  }

  .intro-left {
    background: var(--black);
    border-right: 2px solid var(--black);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 2rem;
    position: relative;
    gap: 1.5rem;
  }

  img {
    width: 50%;
    display: block;
  }

  .intro-color-bar {
    width: 100%;
    height: 4px;
    background: linear-gradient(
      to right,
      var(--blue) 0%,
      var(--blue) 14.28%,
      var(--purple) 14.28%,
      var(--purple) 28.57%,
      var(--yellow) 28.57%,
      var(--yellow) 42.85%,
      var(--orange) 42.85%,
      var(--orange) 57.14%,
      var(--pink) 57.14%,
      var(--pink) 71.42%,
      var(--green) 71.42%,
      var(--green) 85.71%,
      var(--red) 85.71%,
      var(--red) 100%
    );
  }

  .intro-right {
    background: var(--white);
    padding: 2.5rem 3.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .intro-label {
    font-family: var(--font-logo);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--black);
    opacity: 0.4;
    align-self: flex-end;
  }

  h2 {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 500;
    color: var(--black);
    line-height: 1.2;
    margin: auto 0 0;
    align-self: flex-end;
  }

  @media (max-width: 768px) {
    .intro {
      grid-template-columns: 1fr;
    }

    .intro-left {
      border-right: none;
      border-bottom: 2px solid var(--black);
      min-height: 40vw;
    }

    img {
      width: 40%;
    }

    h2 {
      font-size: 2.5rem;
    }

    .intro-right {
      padding: 3rem 2rem;
      gap: 2rem;
    }
  }
</style>
