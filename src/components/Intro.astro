---
import computer from '../../assets/computer.png';
---

<section class="intro">
  <div class="container">
    <img src={computer.src} alt="Computer illustration" />
    <h2>
      Candura is a data-informed design and technology studio. We build digital products, platforms, and interfaces that
      turn complexity into clarity.
    </h2>
  </div>
</section>

<style lang="scss">
  .intro {
    background-color: var(--yellow);
    padding: 6rem 0;
  }

  .container {
    display: flex;
    align-items: center;
    gap: 4rem;

    img {
      width: 15%;
      flex-shrink: 0;
    }
  }

  h2 {
    font-family: var(--font-display);
    font-size: 2.2em;
    font-weight: 300;
    color: var(--red);
    line-height: 1.3;
    margin: 0;
  }
</style>
