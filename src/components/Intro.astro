---
import computer from '../../assets/pixel-computer.svg?url';
---

<section class="intro">
  <div class="container">
    <img src={computer} alt="Computer illustration" />
    <div class="text-container">
      <h2>
        We help brands get where they're going through boundless design and technology sharp enough to execute it.
      </h2>
    </div>
  </div>
</section>

<style lang="scss">
  .intro {
    background-color: var(--yellow);
    height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .container {
    display: flex;
    align-items: center;
    gap: 4rem;

    .text-container {
      width: 65%;
      margin-left: auto;
    }

    img {
      width: 30%;
      margin-left: auto;
      animation: nudge 4s ease-in-out infinite;
    }
  }

  // @keyframes nudge {
  //   0%        { transform: translateX(0px) rotate(0deg); }
  //   20%       { transform: translateX(-6px) rotate(-1deg); }
  //   50%       { transform: translateX(6px) rotate(1deg); }
  //   80%       { transform: translateX(-3px) rotate(-0.5deg); }
  //   100%      { transform: translateX(0px) rotate(0deg); }
  // }

  h2 {
    font-family: var(--font-display);
    font-size: 2.8em;
    font-weight: 400;
    color: var(--red);
    line-height: 1.2;
    margin: 0;
  }
</style>
