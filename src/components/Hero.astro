---
interface Props {
  tagline: string;
}

const { tagline } = Astro.props;
---

<section class="hero">
  <canvas id="node-canvas"></canvas>
  <div class="hero-content">
    <h1 class="tagline">{tagline}</h1>
  </div>
</section>

<script>
  import { NodeNetwork } from '@/scripts/NodeNetwork';

  const canvas = document.getElementById('node-canvas') as HTMLCanvasElement;
  const network = new NodeNetwork(canvas);
  network.start();

  window.addEventListener('pagehide', () => network.destroy());
</script>

<style lang="scss">
  .hero {
    position: relative;
    width: 100%;
    height: 60vh;
    overflow: hidden;
  }

  canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .hero-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    pointer-events: none;
  }

  .tagline {
    font-family: var(--font-body);
    font-size: 3em;
    color: var(--black);
    margin: 0;
  }
</style>
