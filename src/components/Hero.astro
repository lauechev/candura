<script>
  import { GravitySpheres } from '@/scripts/GravitySpheres';

  const canvas = document.getElementById('node-canvas') as HTMLCanvasElement;
  const sim = new GravitySpheres(canvas);
  sim.start();

  window.addEventListener('pagehide', () => sim.destroy());
</script>

<style lang="scss">
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .hero-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    pointer-events: none;
    padding-bottom: 10%;
  }

  .tagline {
    font-family: var(--font-display);
    font-size: 3.5em;
    color: var(--black);
    font-weight: 500;
    margin: 0;
    // background-color: rgba(255, 255, 255, 0.8);
    padding: 0em 0.1em 1em;
    // border-radius: 8px;
  }
</style>
