---
interface Props {
  color: string;
  image: string;
  description: string;
  imageSize?: string;
}

const { color, image, description, imageSize = '60%' } = Astro.props;
---

<div class="photo-card">
  <div class="photo-square" style={`--square-color: ${color}`}>
    <span class="photo-label">{description}</span>
    <img src={image} alt={description} style={`max-width: ${imageSize}; max-height: ${imageSize};`} />
  </div>
</div>

<style lang="scss">
  .photo-card {
    width: 100%;
  }

  .photo-square {
    position: relative;
    aspect-ratio: 1 / 1;
    background-color: var(--white);
    border: 2px solid var(--black);
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 2rem;

    img {
      width: auto;
      height: auto;
      object-fit: contain;
      display: block;
    }
  }

  .photo-label {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--square-color);
    color: var(--white);
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 500;
    padding: 0.4rem 0.9rem;
    border-radius: 10px;
    z-index: 1;
    border: 2px solid var(--black);
    line-height: 1.3;
  }

  @media (max-width: 768px) {
    .photo-label {
      font-size: 0.9rem;
      padding: 0.35rem 0.75rem;
    }
  }
</style>
