---
interface Props {
  color: string;
  image: string;
  description: string;
  imageSize?: string;
}

const { color, image, description, imageSize = '60%' } = Astro.props;
---

<div class="photo-card">
  <span class="photo-label">{description}</span>
  <div class="photo-square">
    <img src={image} alt={description} />
  </div>
</div>

<style lang="scss">
  .photo-card {
    width: 100%;
  }

  .photo-square {
    position: relative;
    aspect-ratio: 16 / 9;
    background-color: var(--white);
    border: 2px solid var(--black);
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 0;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
  }

  .photo-label {
    display: inline-block;
    background: var(--black);
    color: var(--white);
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 500;
    padding: 0.4rem 0.9rem;
    border-radius: 10px;
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  @media (max-width: 768px) {
    .photo-label {
      font-size: 1rem;
      padding: 0.35rem 0.75rem;
    }
  }
</style>
