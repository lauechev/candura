---
const { pathname } = Astro.url;
const isHome = pathname === '/';
const isAbout = pathname.startsWith('/about');
const isServices = pathname.startsWith('/services');
const isWork = pathname.startsWith('/work');
const isContact = pathname.startsWith('/contact');
---

<nav>
  <a href="/" class="wordmark">Candura</a>

  <button class="hamburger" aria-expanded="false" aria-label="Toggle navigation">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <ul class="nav-links">
    <li>
      <a href="/" class:list={['nav-link', { 'is-active': isHome }]} style="--color: var(--green); --text: var(--white)"
        >Home</a
      >
    </li>
    <li>
      <a
        href="/about"
        class:list={['nav-link', { 'is-active': isAbout }]}
        style="--color: var(--blue); --text: var(--white)">About</a
      >
    </li>
    <li>
      <a
        href="/services"
        class:list={['nav-link', { 'is-active': isServices }]}
        style="--color: var(--purple); --text: var(--white)">Services</a
      >
    </li>
    <li>
      <a
        href="/work"
        class:list={['nav-link', { 'is-active': isWork }]}
        style="--color: var(--yellow); --text: var(--black)">Work</a
      >
    </li>
    <li>
      <a
        href="/contact"
        class:list={['nav-link', { 'is-active': isContact }]}
        style="--color: var(--red); --text: var(--white)">Contact</a
      >
    </li>
  </ul>
</nav>

<script>
  const btn = document.querySelector('.hamburger') as HTMLButtonElement;
  const links = document.querySelector('.nav-links') as HTMLElement;

  btn.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    links.classList.toggle('is-open');
  });
</script>

<style lang="scss">
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    background-color: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
  }

  .wordmark {
    font-family: var(--font-display);
    color: var(--black);
    font-size: 1.6rem;
    font-weight: 500;
  }

  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.75rem;
  }

  .nav-link {
    display: inline-block;
    padding: 0.625rem 1.3125rem;
    border: 2px solid var(--color);
    border-radius: 10px;
    color: var(--black);
    background-color: transparent;
    font-family: var(--font-body);
    font-size: 0.9rem;
    transition:
      background-color 150ms ease,
      color 150ms ease;

    &:hover,
    &.is-active {
      background-color: var(--color);
      color: var(--text);
    }
  }

  .hamburger {
    display: none;
  }

  @media (max-width: 640px) {
    nav {
      flex-wrap: wrap;
      padding: 1rem;
    }

    .hamburger {
      display: flex;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.25rem;

      span {
        display: block;
        width: 24px;
        height: 2px;
        background: var(--black);
        transition:
          transform 200ms ease,
          opacity 200ms ease;
      }

      &[aria-expanded='true'] span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
      }
      &[aria-expanded='true'] span:nth-child(2) {
        opacity: 0;
      }
      &[aria-expanded='true'] span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
      }
    }

    .nav-links {
      display: none;
      flex-direction: column;
      width: 100%;
      padding: 0.5rem 0 1rem;
      gap: 0.5rem;

      &.is-open {
        display: flex;
      }
    }
  }
</style>
