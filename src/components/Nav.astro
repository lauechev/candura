---
const { pathname } = Astro.url;
const isAbout = pathname.startsWith('/about');
const isServices = pathname.startsWith('/services');
const isWork = pathname.startsWith('/work');
const isContact = pathname.startsWith('/contact');
---

<div class="nav-wrapper">
  <nav>
    <a href="/" class="wordmark">Candura</a>

    <button class="hamburger" aria-expanded="false" aria-label="Toggle navigation">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <ul class="nav-links">
      <li>
        <a
          href="/about"
          class:list={['nav-link', { 'is-active': isAbout }]}
          style="--color: var(--blue); --text: var(--white)">about</a
        >
      </li>
      <li>
        <a
          href="/services"
          class:list={['nav-link', { 'is-active': isServices }]}
          style="--color: var(--purple); --text: var(--white)">services</a
        >
      </li>

      <li>
        <a
          href="/contact"
          class:list={['nav-link', { 'is-active': isContact }]}
          style="--color: var(--orange); --text: var(--white)">contact</a
        >
      </li>
    </ul>
  </nav>
</div>

<script>
  const nav = document.querySelector('nav') as HTMLElement;
  const btn = document.querySelector('.hamburger') as HTMLButtonElement;
  const links = document.querySelector('.nav-links') as HTMLElement;

  window.addEventListener(
    'scroll',
    () => {
      nav.classList.toggle('is-scrolled', window.scrollY > 0);
    },
    { passive: true }
  );

  btn.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    links.classList.toggle('is-open');
  });
</script>

<style lang="scss">
  .nav-wrapper {
    position: fixed;
    top: 1.6%;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    pointer-events: none;
  }

  nav {
    width: 60%;
    pointer-events: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.8rem 2rem;
    border: 2px solid var(--black);
    border-radius: 15px;
  }

  .wordmark {
    font-family: var(--font-logo);
    color: var(--black);
    font-size: 1.6rem;
    font-weight: 500;
    transition: opacity 150ms ease;

    &:hover {
      opacity: 0.7;
    }
  }

  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.75rem;
  }

  .nav-link {
    display: inline-block;
    padding: 0.6rem 1.3rem;
    border-radius: 10px;
    color: var(--black);
    // background-color: var(--color);
    border: 2px solid var(--color);
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1.2rem;
    // box-shadow:
    //   inset 2px 2px 0 color-mix(in srgb, var(--color), white 50%),
    //   inset -2px -2px 0 color-mix(in srgb, var(--color), black 40%);

    &:hover {
      background-color: var(--color);
      color: (var(--white));
      // opacity: 0.9;
    }

    &:active,
    &.is-active {
      //   box-shadow:
      //     inset 2px 2px 0 color-mix(in srgb, var(--color), black 40%),
      //     inset -2px -2px 0 color-mix(in srgb, var(--color), white 50%);
      //   color: var(--text);
      background-color: var(--color);
      color: (var(--white));
    }
  }

  .hamburger {
    display: none;
  }

  @media (max-width: 640px) {
    nav {
      flex-wrap: wrap;
      padding: 1rem;
      width: 100%;
    }

    .hamburger {
      display: flex;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.25rem;

      span {
        display: block;
        width: 24px;
        height: 2px;
        background: var(--black);
        transition:
          transform 200ms ease,
          opacity 200ms ease;
      }

      &[aria-expanded='true'] span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
      }
      &[aria-expanded='true'] span:nth-child(2) {
        opacity: 0;
      }
      &[aria-expanded='true'] span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
      }
    }

    .nav-links {
      display: none;
      flex-direction: column;
      width: 100%;
      padding: 0.5rem 0 0.5rem;
      gap: 0.5rem;

      &.is-open {
        display: flex;
      }
    }
  }
</style>
