---
const { pathname } = Astro.url;
const isAbout = pathname.startsWith('/about');
const isServices = pathname.startsWith('/services');
const isWork = pathname.startsWith('/work');
const isContact = pathname.startsWith('/contact');
---

<div class="nav-wrapper">
  <nav>
    <a href="/" class="wordmark">Candura</a>

    <button class="hamburger" aria-expanded="false" aria-label="Toggle navigation">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <ul class="nav-links">
      <li>
        <a
          href="/about"
          class:list={['nav-link', { 'is-active': isAbout }]}
          style="--color: var(--blue); --text: var(--white)">about</a
        >
      </li>
      <li>
        <a
          href="/services"
          class:list={['nav-link', { 'is-active': isServices }]}
          style="--color: var(--purple); --text: var(--white)">services</a
        >
      </li>
      <li>
        <a
          href="/work"
          class:list={['nav-link', { 'is-active': isWork }]}
          style="--color: var(--pink); --text: var(--white)">work</a
        >
      </li>
      <li>
        <a
          href="/contact"
          class:list={['nav-link', { 'is-active': isContact }]}
          style="--color: var(--orange); --text: var(--white)">contact</a
        >
      </li>
    </ul>

    <!-- Dropdown mobile menu -->
    <div class="mobile-overlay" id="mobile-overlay" aria-hidden="true">
      <ul class="overlay-links">
        <li>
          <a href="/about" class:list={['overlay-link', { 'is-active': isAbout }]} style="--color: var(--blue)">about</a
          >
        </li>
        <li>
          <a href="/services" class:list={['overlay-link', { 'is-active': isServices }]} style="--color: var(--purple)"
            >services</a
          >
        </li>
        <li>
          <a href="/work" class:list={['overlay-link', { 'is-active': isWork }]} style="--color: var(--pink)"
            >work</a
          >
        </li>
        <li>
          <a href="/contact" class:list={['overlay-link', { 'is-active': isContact }]} style="--color: var(--orange)"
            >contact</a
          >
        </li>
      </ul>
    </div>
  </nav>
</div>

<script>
  const nav = document.querySelector('nav') as HTMLElement;
  const btn = document.querySelector('.hamburger') as HTMLButtonElement;
  const overlay = document.getElementById('mobile-overlay') as HTMLElement;
  const overlayLinks = document.querySelectorAll('.overlay-link');

  function openMenu() {
    btn.setAttribute('aria-expanded', 'true');
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
  }

  function closeMenu() {
    btn.setAttribute('aria-expanded', 'false');
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
  }

  window.addEventListener(
    'scroll',
    () => {
      nav.classList.toggle('is-scrolled', window.scrollY > 0);
    },
    { passive: true }
  );

  btn.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    expanded ? closeMenu() : openMenu();
  });

  overlayLinks.forEach((link) => link.addEventListener('click', closeMenu));
</script>

<style lang="scss">
  .nav-wrapper {
    position: fixed;
    top: 1.6%;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    justify-content: center;
    pointer-events: none;
  }

  nav {
    position: relative;
    width: 50%;
    pointer-events: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.45rem 1.5rem;
    border: 2px solid var(--black);
    border-radius: 10px;
    background: var(--white);
  }

  .wordmark {
    font-family: var(--font-logo);
    color: var(--black);
    font-size: 1.6rem;
    font-weight: 500;
    transition: opacity 150ms ease;
    letter-spacing: -4%;

    &:hover {
      opacity: 0.7;
    }
  }

  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.75rem;
  }

  .nav-link {
    display: inline-block;
    padding: 0.3rem 1rem;
    margin-right: 0.5rem;
    border-radius: 8px;
    color: var(--black);
    border: 1px solid transparent;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1.1rem;

    &:hover {
      background-color: var(--color);
      color: var(--white);
      border: 1.8px solid var(--black);
    }

    &:active,
    &.is-active {
      background-color: var(--color);
      color: var(--white);
      border: 1.8px solid var(--black);
    }
  }

  .hamburger {
    display: none;
  }

  // ── Dropdown mobile menu ────────────────────────────────────────────────────
  .mobile-overlay {
    display: none;
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    // width: 90vw;
    height: 10vh;
    z-index: 200;
    background: var(--white);
    border: 2px solid var(--black);
    border-radius: 15px;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    padding: 1.2rem 1.5rem;

    &.is-open {
      display: flex;
    }
  }

  .overlay-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.75rem;
  }

  .overlay-link {
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--black);
    padding: 0.4rem 1.2rem;
    border-radius: 8px;
    border: 1px solid transparent;
    transition: background-color 150ms ease;

    &:hover,
    &.is-active {
      background-color: var(--color);
      color: var(--white);
      border: 1.8px solid var(--black);
    }
  }

  // ── Tablet ─────────────────────────────────────────────────────────────────
  @media (max-width: 1024px) {
    nav {
      width: 75%;
    }

    .nav-link {
      padding: 0.4rem 0.8rem;
      font-size: 1rem;
    }
  }

  // ── Mobile (hamburger kicks in) ────────────────────────────────────────────
  @media (max-width: 760px) {
    nav {
      width: 85%;
      padding: 0.8rem 1.5rem;
      border: 1.5px solid var(--black);
    }

    .nav-links {
      display: none;
    }

    .hamburger {
      display: flex;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.25rem;
      pointer-events: auto;

      span {
        display: block;
        width: 24px;
        height: 2px;
        transition:
          transform 200ms ease,
          opacity 200ms ease;
      }

      span:nth-child(1) {
        background: var(--red);
      }
      span:nth-child(2) {
        background: var(--green);
      }
      span:nth-child(3) {
        background: var(--orange);
      }

      &[aria-expanded='true'] span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
      }
      &[aria-expanded='true'] span:nth-child(2) {
        opacity: 0;
      }
      &[aria-expanded='true'] span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
      }
    }

    .mobile-overlay {
      width: 70vw;
      border: 1.5px solid var(--black);
    }
  }

  // ── Small mobile ───────────────────────────────────────────────────────────
  @media (max-width: 500px) {
    nav {
      width: 90%;
      padding: 0.7rem 1.2rem;
    }

    .mobile-overlay {
      width: 90vw;
    }
  }

  // ── Very small mobile ──────────────────────────────────────────────────────
  @media (max-width: 410px) {
    .overlay-link {
      font-size: 1.3rem;
      padding: 0.25rem 0.6rem;
    }

    .mobile-overlay {
      left: 0;
      right: 0;
      width: auto;
      padding: 0.8rem 1rem;
      gap: 0.4rem;
    }
  }
</style>
