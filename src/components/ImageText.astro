---
interface Props {
  color: string;
  title: string;
  description: string;
  image: string;
  reverse?: boolean;
}

const { color, title, description, image, reverse = false } = Astro.props;
---

<div class:list={['about-split', { 'about-split--reverse': reverse }]}>
  <div class="split-text">
    <h2>{title}</h2>
    <p>{description}</p>
  </div>
  <div class="split-image" style={`--square-color: ${color}`}>
    <img src={image} alt={title} />
  </div>
</div>

<style lang="scss">
  .about-split {
    display: grid;
    grid-template-columns: 1fr 60vh;
    grid-template-areas: 'text image';
    border: 2px solid var(--black);
    border-radius: 15px;
    overflow: hidden;
    height: 50vh;
    width: 98vw;
    margin: 0 auto 1rem;
  }

  .about-split--reverse {
    grid-template-columns: 60vh 1fr;
    grid-template-areas: 'image text';
  }

  .split-text {
    grid-area: text;
    background: var(--white);
    padding: 3.5rem 4rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    border-right: 2px solid var(--black);

    .about-split--reverse & {
      border-right: none;
      border-left: 2px solid var(--black);
      text-align: right;
    }
  }

  .split-image {
    grid-area: image;
    background-color: var(--square-color);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5rem;
    overflow: hidden;

    img {
      max-width: 100%;
      max-height: 100%;
      width: auto;
      height: auto;
      object-fit: contain;
      display: block;
    }
  }

  h2 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    font-weight: 500;
    color: var(--black);
    margin: 0 0 1.25rem;
    letter-spacing: 0;
  }

  p {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--black);
    margin: 0;
  }

  /* ── Tablet & Mobile ─────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .about-split,
    .about-split--reverse {
      display: flex;
      flex-direction: column;
      height: auto;
    }

    .split-image {
      order: -1;
      height: 40vw;
      padding: 1.5rem;
      border-bottom: 2px solid var(--black);

      img {
        width: auto;
        max-width: 90%;
        max-height: 100%;
        height: 100%;
      }
    }

    .split-text,
    .about-split--reverse .split-text {
      order: 0;
      border-right: none;
      border-left: none;
      padding: 2.5rem;
      text-align: left;
    }

    h2 {
      font-size: clamp(1.8rem, 6vw, 3rem);
    }
  }

  /* ── Small mobile ────────────────────────────────────────────────────── */
  @media (max-width: 500px) {
    .split-image {
      height: 60vw;
    }

    .split-text {
      padding: 2rem 1.5rem;
      justify-content: flex-start;
    }

    h2 {
      font-size: 1.6rem;
      margin-bottom: 0.75rem;
    }

    p {
      font-size: 0.95rem;
    }

    img {
      width: auto;
      max-width: 90%;
      max-height: 100%;
      height: 100%;
    }
  }
</style>
